<%- include('partials/header', { title: '로그인' }) %>

<div class="auth-wrap">
  <div class="auth-card">
    <div class="auth-logo">
      <h1>Kjobs</h1>
      <p>구직 커뮤니티에 오신 걸 환영합니다</p>
    </div>

    <% if (locals.registered) { %>
      <div class="alert alert-success">가입이 완료되었습니다. 로그인해 주세요.</div>
    <% } %>

    <% if (locals.error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/login" method="POST" class="form">
      <div class="form-group">
        <label for="username">아이디</label>
        <input
          type="text"
          id="username"
          name="username"
          value="<%= locals.username || '' %>"
          autocomplete="username"
          required
          autofocus
        />
      </div>
      <div class="form-group">
        <label for="password">비밀번호</label>
        <input
          type="password"
          id="password"
          name="password"
          autocomplete="current-password"
          required
        />
      </div>
      <button type="submit" class="btn btn-primary btn-block">로그인</button>
    </form>

    <p class="auth-footer">
      아직 계정이 없으신가요? <a href="/register">회원가입</a>
    </p>
  </div>
</div>

<%- include('partials/footer') %>
