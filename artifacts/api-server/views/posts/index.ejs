<%- include('../partials/header', { title: isSearch ? '검색 결과' : '게시판' }) %>

<div class="page-header">
  <h2><%= isSearch ? '검색 결과' : '자유게시판' %></h2>
  <a href="<%= base %>/posts/new" class="btn btn-primary">글쓰기</a>
</div>

<form action="<%= base %>/posts" method="GET" class="search-form">
  <select name="searchType" class="search-select">
    <option value="title" <%= searchType === 'title' ? 'selected' : '' %>>제목</option>
    <option value="titleContent" <%= searchType === 'titleContent' ? 'selected' : '' %>>제목+내용</option>
    <option value="nickname" <%= searchType === 'nickname' ? 'selected' : '' %>>작성자</option>
  </select>
  <input type="text" name="search" value="<%= search %>"
    placeholder="검색어를 입력하세요" class="search-input" />
  <button type="submit" class="btn btn-secondary">검색</button>
  <% if (isSearch) { %>
    <a href="<%= base %>/posts" class="btn btn-outline">초기화</a>
  <% } %>
</form>

<% if (isSearch) { %>
  <p class="search-info">
    "<strong><%= search %></strong>" 검색 결과 — 총 <strong><%= total %></strong>건
  </p>
<% } %>

<% if (posts.length === 0) { %>
  <div class="empty">
    <p><%= isSearch ? '검색 결과가 없습니다.' : '아직 작성된 글이 없습니다.' %></p>
  </div>
<% } else { %>
  <table class="post-table">
    <thead>
      <tr>
        <th class="col-num">번호</th>
        <th class="col-title">제목</th>
        <th class="col-author">작성자</th>
        <th class="col-date">작성일</th>
        <th class="col-views">조회</th>
      </tr>
    </thead>
    <tbody>
      <% posts.forEach((post, idx) => { %>
        <tr>
          <td class="col-num text-muted"><%= (page - 1) * 20 + idx + 1 %></td>
          <td class="col-title"><a href="<%= base %>/posts/<%= post.id %>"><%= post.title %></a></td>
          <td class="col-author text-muted"><%= post.nickname %></td>
          <td class="col-date text-muted"><%= post.created_at.slice(0, 10) %></td>
          <td class="col-views text-muted"><%= post.view_count %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %>
        <a href="<%= base %>/posts?page=<%= page - 1 %><%= search ? '&search=' + encodeURIComponent(search) + '&searchType=' + searchType : '' %>" class="page-btn">&laquo; 이전</a>
      <% } %>
      <% for (let i = Math.max(1, page - 4); i <= Math.min(totalPages, page + 4); i++) { %>
        <a href="<%= base %>/posts?page=<%= i %><%= search ? '&search=' + encodeURIComponent(search) + '&searchType=' + searchType : '' %>"
           class="page-btn <%= i === page ? 'active' : '' %>"><%= i %></a>
      <% } %>
      <% if (page < totalPages) { %>
        <a href="<%= base %>/posts?page=<%= page + 1 %><%= search ? '&search=' + encodeURIComponent(search) + '&searchType=' + searchType : '' %>" class="page-btn">다음 &raquo;</a>
      <% } %>
    </div>
  <% } %>
<% } %>

<%- include('../partials/footer') %>
